@page
@model IndexModel
@{
    ViewData["Title"] = "Marcas Blancas";
}

<div class="container mt-5">

    <div class="hero text-center">
        <h1>🛒 Descubre las Marcas Blancas</h1>
        <h4>Calidad garantizada a precios más bajos</h4>
        <p>
            Conoce por qué millones de consumidores eligen marcas blancas y ahorran en sus compras diarias.
        </p>
        <a href="#beneficios" class="btn btn-warning btn-lg">
            Ver Beneficios
        </a>
    </div>

    <br>

    <div class="row text-center">

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h2>💲</h2>
                    <h4>Precios Bajos</h4>
                    <p>
                        Ahorra hasta un 50% en productos de alimentación y bebidas.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h2>⭐</h2>
                    <h4>Calidad Garantizada</h4>
                    <p>
                        Elaborados por fabricantes reconocidos y con altos estándares de calidad.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow">
                <div class="card-body">
                    <h2>📈</h2>
                    <h4>Mayor Popularidad</h4>
                    <p>
                        Actualmente representan el 22% del mercado y continúan creciendo.
                    </p>
                </div>
            </div>
        </div>

    </div>

    <br><br>

    <section id="beneficios">

        <div class="text-center">
            <h2>¿Por qué elegir Marcas Blancas?</h2>
            <hr>
        </div>

        <div class="row">

            <div class="col-md-6">
                <div class="card border-success shadow">
                    <div class="card-header bg-success text-white">
                        ✔ Beneficios
                    </div>

                    <div class="card-body">
                        <ul>
                            <li>Productos económicos.</li>
                            <li>Excelente relación calidad-precio.</li>
                            <li>Fabricados por empresas reconocidas.</li>
                            <li>Amplia variedad de productos.</li>
                            <li>Mayor ahorro para las familias.</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="col-md-6">

                <div class="card border-info shadow">
                    <div class="card-header bg-info text-white">
                        📊 Datos del Mercado
                    </div>

                    <div class="card-body">
                        <h5>22%</h5>
                        <p>Participación actual en el mercado español.</p>

                        <h5>45%</h5>
                        <p>Proyección de crecimiento en los próximos años.</p>

                        <h5>50%</h5>
                        <p>Ahorro en algunos productos preparados.</p>
                    </div>

                </div>

            </div>

        </div>

    </section>

    <br><br>

    <div class="card shadow">

        <div class="card-header bg-dark text-white">
            🥛 Ejemplo de Ahorro
        </div>

        <div class="card-body">

            <table class="table table-striped table-hover">

                <thead class="table-primary">
                    <tr>
                        <th>Producto</th>
                        <th>Marca Tradicional</th>
                        <th>Marca Blanca</th>
                        <th>Ahorro</th>
                    </tr>
                </thead>

                <tbody>

                    <tr>
                        <td>Leche</td>
                        <td>S/ 5.50</td>
                        <td>S/ 3.80</td>
                        <td class="text-success">S/ 1.70</td>
                    </tr>

                    <tr>
                        <td>Yogurt</td>
                        <td>S/ 7.00</td>
                        <td>S/ 4.50</td>
                        <td class="text-success">S/ 2.50</td>
                    </tr>

                    <tr>
                        <td>Gaseosa</td>
                        <td>S/ 8.00</td>
                        <td>S/ 5.20</td>
                        <td class="text-success">S/ 2.80</td>
                    </tr>

                </tbody>

            </table>

        </div>

    </div>

    <br>

    <div class="compra-inteligente text-center">

        <h3>🎯 Compra Inteligente</h3>

        <p>
            Las marcas blancas ofrecen calidad y ahorro, convirtiéndose en una excelente alternativa para el consumidor moderno.
        </p>

    </div>

</div>